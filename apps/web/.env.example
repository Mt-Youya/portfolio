# DeepSeek API, required for /api/agent generated answer
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# GitHub token, optional. Raises API rate limit and enables GraphQL pinned item count.
GITHUB_TOKEN=

# Upstash Redis, optional. Enables shared 10-minute cache in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legacy Vercel KV variable names, optional fallback.
KV_REST_API_URL=
KV_REST_API_TOKEN=
