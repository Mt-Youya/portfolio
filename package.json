{
  "name": "cyrus-portfolio",
  "version": "0.0.1",
  "private": true,
  "devDependencies": {
    "@types/node": "^26.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @cyrus/web dev",
    "build": "pnpm --filter @cyrus/web build",
    "typecheck": "pnpm --filter @cyrus/web typecheck",
    "lint": "oxlint .",
    "fmt": "oxfmt --write ."
  }
}